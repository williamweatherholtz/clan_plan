# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://clanplan:clanplan@localhost:5432/clanplan

# ── Session ───────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 64
SESSION_SECRET=change_me_generate_with_openssl_rand_hex_64

# ── Google OAuth2 (optional — leave empty to disable Google login) ─────────────
# Register at: https://console.cloud.google.com/apis/credentials
# Scopes needed: openid, email, profile (no app review required for these)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=http://localhost:8080/api/auth/google/callback

# ── Application ───────────────────────────────────────────────────────────────
APP_BASE_URL=http://localhost:8080
# Port the app listens on inside the container / locally
APP_PORT=8080

# ── Email / SMTP ──────────────────────────────────────────────────────────────
# Dev default points to Mailpit (included in docker-compose.yml)
# Mailpit web UI: http://localhost:8025
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=clanplan@localhost
# Set to "true" to require STARTTLS / TLS
SMTP_TLS=false

# ── Bootstrap admin account ───────────────────────────────────────────────────
# Created automatically on first boot if no sysadmin exists.
# Credentials are logged if these are not overridden.
# Override both to suppress the default-credentials warning.
ADMIN_EMAIL=admin@localhost
ADMIN_PASSWORD=password

# ── Media Storage ─────────────────────────────────────────────────────────────
# Absolute path on the host (or container) where uploads are stored.
# Mapped to /data/media in docker-compose.yml via a named volume.
MEDIA_STORAGE_PATH=./media
# Max single-file upload size in bytes (default: 100 MB)
MAX_UPLOAD_BYTES=104857600
